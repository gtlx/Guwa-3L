---
import BackToTop from "@shared/components/control/BackToTop.astro";
import Footer from "@features/layout/components/Footer.astro";
import Navbar from "@features/layout/components/Navbar.astro";
import SideBar from "@features/widgets/SideBar.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import TOC from "@features/widgets/TOC.astro";
import { siteConfig } from "@/config";
import { url } from "@shared/utils/url-utils";
import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	MAIN_PANEL_OVERLAPS_BANNER_HEIGHT,
} from "@shared/constants/constants";
import Layout from "./Layout.astro";
import fs from "fs";
import path from "path";

const BANNER_DIR = path.resolve("blog/assets/public/banner");
let bannerImages: string[] = [];
if (siteConfig.banner.images && siteConfig.banner.images.length > 0) {
	bannerImages = siteConfig.banner.images;
} else if (fs.existsSync(BANNER_DIR)) {
	bannerImages = fs
		.readdirSync(BANNER_DIR)
		.filter((f) => /\.(jpe?g|png|gif|webp|avif)$/i.test(f))
		.sort()
		.map((f) => `/banner/${f}`);
}

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	headings?: MarkdownHeading[];
}

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	headings = [],
} = Astro.props;
const hasBannerCredit =
	siteConfig.banner.enable && siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;

const mainPanelTop = siteConfig.banner.enable
	? `calc(${BANNER_HEIGHT}vh - ${MAIN_PANEL_OVERLAPS_BANNER_HEIGHT}rem)`
	: "5.5rem";
---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle}>

<!-- 导航栏 -->
<slot slot="head" name="head"></slot>
<div id="top-row" class="z-50 pointer-events-none relative transition-all duration-700 max-w-[var(--page-width)] px-0 md:px-4 mx-auto" class:list={[""]}>
    <div id="navbar-wrapper" class="pointer-events-auto sticky top-0 transition-all">
        <Navbar></Navbar>
    </div>
</div>

<!-- 横幅轮播 -->
{siteConfig.banner.enable && bannerImages.length > 0 && <div id="banner-wrapper" class={`absolute z-10 w-full transition duration-700 overflow-hidden`} style={`top: -${BANNER_HEIGHT_EXTEND}vh`}>
    <div id="banner-carousel" class="relative h-full w-full">
        {bannerImages.map((imgSrc, i) => (
            <img src={url(imgSrc)} alt="" class="carousel-slide" data-index={i}
                 style={`object-position: ${siteConfig.banner.position || "center"}`}
            />
        ))}
    </div>
    {bannerImages.length > 1 && <>
        <button id="banner-prev" class="banner-arrow left-4" aria-label="上一张">‹</button>
        <button id="banner-next" class="banner-arrow right-4" aria-label="下一张">›</button>
        <div id="banner-dots" class="absolute bottom-4 left-1/2 z-20 flex -translate-x-1/2 gap-2">
            {bannerImages.map((_, i) => (
                <button class="banner-dot" data-index={i} aria-label={`切换到第 ${i + 1} 张`}></button>
            ))}
        </div>
    </>}
</div>}

<!-- 主内容 -->
<div class="absolute w-full z-30 pointer-events-none" style={`top: ${mainPanelTop}`}>
    <!-- 此处 pointer-events-none 防止阻挡 TOC 的点击事件 -->
    <div class="relative max-w-[var(--page-width)] mx-auto pointer-events-auto">
        <div id="main-grid" class="transition duration-700 w-full left-0 right-0 grid grid-cols-[17.5rem_auto] grid-rows-[auto_1fr_auto] lg:grid-rows-[auto]
    mx-auto gap-4 px-0 md:px-4"
        >
            <!-- 横幅图片来源 -->
            {hasBannerCredit && <a href={siteConfig.banner.credit.url} id="banner-credit" target="_blank" rel="noopener" aria-label="Visit image source"
                                   class:list={["group onload-animation transition-all absolute flex justify-center items-center rounded-full " +
                                   "px-3 right-4 -top-[3.25rem] bg-black/60 hover:bg-black/70 h-9", {"hover:pr-9 active:bg-black/80": hasBannerLink}]}
            >
                <Icon class="text-white/75 text-[1.25rem] mr-1" name="material-symbols:copyright-outline-rounded" ></Icon>
                <div class="text-white/75 text-xs">{siteConfig.banner.credit.text}</div>
                <Icon class:list={["transition absolute text-[oklch(0.75_0.14_var(--hue))] right-4 text-[0.75rem] opacity-0",
                    {"group-hover:opacity-100": hasBannerLink}]}
                      name="fa6-solid:arrow-up-right-from-square">
                </Icon>
            </a>}


            <SideBar class="mb-4 row-start-2 row-end-3 col-span-2 lg:row-start-1 lg:row-end-2 lg:col-span-1 lg:max-w-[17.5rem] onload-animation" headings={headings}></SideBar>

            <main id="swup-container" class="transition-swup-fade col-span-2 lg:col-span-1 overflow-hidden">
                <div id="content-wrapper" class="onload-animation">
                    <!-- 此处 overflow-hidden 防止长文本破坏布局 -->
                    <!-- 使 id 与 windows.swup 全局属性不同 -->
                    <slot></slot>
                    <div class="footer col-span-2 onload-animation hidden lg:block">
                        <Footer></Footer>
                    </div>
                </div>
            </main>

            <div class="footer col-span-2 onload-animation block lg:hidden">
                <Footer></Footer>
            </div>
        </div>

        <BackToTop></BackToTop>
    </div>
</div>

<!-- 横幅下方的元素，目前只有 TOC -->
<div class="absolute w-full z-0 hidden 2xl:block">
    <div class="relative max-w-[var(--page-width)] mx-auto">
        <!-- TOC 组件 -->
        {siteConfig.toc.enable && <div id="toc-wrapper" class:list={["hidden lg:block transition absolute top-0 -right-[var(--toc-width)] w-[var(--toc-width)] items-center",
            {"toc-hide": siteConfig.banner.enable}]}
        >
            <div id="toc-inner-wrapper" class="fixed top-14 w-[var(--toc-width)] h-[calc(100vh_-_20rem)] overflow-y-scroll overflow-x-hidden hide-scrollbar">
                <div id="toc" class="w-full h-full transition-swup-fade ">
                    <div class="h-8 w-full"></div>
                    <TOC headings={headings}></TOC>
                    <div class="h-8 w-full"></div>
                </div>
            </div>
        </div>}

        <!-- #toc 必须存在，Swup 才能正常工作 -->
        {!siteConfig.toc.enable && <div id="toc"></div>}
    </div>
</div>
</Layout>

<style is:global>
	.carousel-slide {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0;
		transition: opacity 1s ease;
		z-index: 1;
	}
	.carousel-slide.active {
		opacity: 1;
		z-index: 2;
	}
	.banner-arrow {
		position: absolute;
		top: 50%;
		z-index: 10;
		transform: translateY(-50%);
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 9999px;
		background: rgba(0,0,0,0.35);
		color: #fff;
		font-size: 1.5rem;
		line-height: 2.5rem;
		text-align: center;
		border: none;
		cursor: pointer;
		transition: background 0.2s;
		opacity: 0;
		transition: opacity 0.3s, background 0.2s;
	}
	#banner-wrapper:hover .banner-arrow {
		opacity: 1;
	}
	.banner-arrow:hover {
		background: rgba(0,0,0,0.6);
	}
	.banner-dot {
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 9999px;
		border: none;
		background: rgba(255,255,255,0.4);
		cursor: pointer;
		transition: background 0.2s, transform 0.2s;
		padding: 0;
	}
	.banner-dot.active {
		background: #fff;
		transform: scale(1.3);
	}
</style>

<script>
(function() {
	const wrapper = document.getElementById("banner-wrapper");
	if (!wrapper) return;

	const slides = wrapper.querySelectorAll(".carousel-slide");
	if (slides.length < 2) {
		slides[0]?.classList.add("active");
		return;
	}

	let current = 0;
	let timer = null;
	const interval = 5000;

	function goTo(index) {
		slides[current]?.classList.remove("active");
		wrapper.querySelectorAll(".banner-dot").forEach((d) => d.classList.remove("active"));
		current = (index + slides.length) % slides.length;
		slides[current]?.classList.add("active");
		wrapper.querySelector(`.banner-dot[data-index="${current}"]`)?.classList.add("active");
	}

	function next() { goTo(current + 1); resetTimer(); }
	function prev() { goTo(current - 1); resetTimer(); }

	function resetTimer() {
		if (timer) clearInterval(timer);
		timer = setInterval(next, interval);
	}

	slides[0]?.classList.add("active");
	wrapper.querySelector(`.banner-dot[data-index="0"]`)?.classList.add("active");

	document.getElementById("banner-next")?.addEventListener("click", next);
	document.getElementById("banner-prev")?.addEventListener("click", prev);
	wrapper.querySelectorAll(".banner-dot").forEach((dot) => {
		dot.addEventListener("click", () => goTo(Number(dot.dataset.index)));
	});

	timer = setInterval(next, interval);

	wrapper.addEventListener("mouseenter", () => { if (timer) clearInterval(timer); });
	wrapper.addEventListener("mouseleave", resetTimer);
})();
</script>
